{
  "name": "react-menu",
  "nacp": {
    "title": "React Menu",
    "id": "0100d046e70f0000"
  },
  "version": "0.1.0",
  "private": true,
  "description": "A minimalist home menu for the Nintendo Switch, built with React.",
  "scripts": {
    "dev": "vite",
    "preview": "vite build && vite preview",
    "build:browser": "vite build",
    "copy-assets": "mkdir -p romfs && cp -r public/* romfs/",
    "build:switch": "npm run copy-assets && esbuild --bundle --sourcemap --sources-content=false --target=es2022 --format=esm src/main.tsx --outfile=romfs/main.js",
    "build": "npm run build:switch",
    "nro": "npm run build:switch && nxjs-nro",
    "nsp": "npm run build:switch && nxjs-nsp"
  },
  "license": "MIT",
  "devDependencies": {
    "@nx.js/nro": "^0.0.70",
    "@nx.js/nsp": "^0.0.70",
    "@nx.js/runtime": "^0.0.70",
    "@nx.js/constants": "^0.4.0",
    "@types/react": "^18.2.56",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.27.3",
    "vite": "^8.0.10"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-tela": "1.0.1"
  },
  "author": {
    "name": "Liam Sullivan",
    "email": "75332524+liambsulliva@users.noreply.github.com"
  }
}
